generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agreement {
  id                 String    @id @default(cuid())
  type               String
  status             String    @default("draft")

  address            String
  sellers            String

  companyBuyer       String?
  offerPrice         String?
  closingDate        String?
  earnestMoney       String?
  equityPct          String?
  termLength         String?
  agentName          String?
  agentEmail         String?
  agentPhone         String?
  agentLicense       String?
  brokerageName      String?
  listPrice          String?
  agencyRelationship String?
  brokerComp         String?
  listingStart       String?
  listingEnd         String?

  notes              String?
  pdfUrl             String?

  // Signing
  signerName         String?
  signerEmail        String?
  signerToken        String?   @unique
  signedAt           DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([type])
  @@index([status])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  type      String?
  company   String?
  source    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AdminConfig {
  id           String  @id @default("singleton")
  passwordHash String?
}
