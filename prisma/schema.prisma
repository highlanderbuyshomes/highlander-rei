generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agreement {
  id                 String   @id @default(cuid())
  type               String
  status             String   @default("draft")

  address            String
  sellers            String

  companyBuyer       String?
  offerPrice         String?
  closingDate        String?
  earnestMoney       String?

  equityPct          String?
  termLength         String?

  agentName          String?
  agentEmail         String?
  agentPhone         String?
  agentLicense       String?
  brokerageName      String?
  listPrice          String?
  agencyRelationship String?
  brokerComp         String?
  listingStart       String?
  listingEnd         String?

  notes              String?
  pdfUrl             String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([type])
  @@index([status])
}
